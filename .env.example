# ============================================
#   CRYPTO SCALPING BOT - Variables de Entorno
# ============================================

# --- TELEGRAM ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id_here

# --- BINANCE TESTNET (Demo) ---
BINANCE_API_KEY=your_binance_testnet_api_key
BINANCE_SECRET_KEY=your_binance_testnet_secret_key
BINANCE_TESTNET=true

# --- BASE DE DATOS (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# --- CONFIGURACION DEL BOT ---
INITIAL_CAPITAL=1000        # Capital inicial en USDT
MAX_RISK_PER_TRADE=2        # % máximo de riesgo por operación
COMPOUND_REINVEST=80        # % de ganancias a reinvertir (interés compuesto)
MAX_OPEN_TRADES=3           # Máximo de operaciones simultáneas

# --- MODO ---
BOT_MODE=demo               # demo | live
LOG_LEVEL=INFO
